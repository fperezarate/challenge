# Copia este archivo a .env y define los valores (no versionar .env).
# POSTGRES_PASSWORD es obligatorio para que el backend y la DB coincidan.
# Frontend (Next.js): NEXT_PUBLIC_APP_VERSION y NEXT_PUBLIC_API_BASE_URL son opcionales.

NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081

POSTGRES_DB=tenpo
POSTGRES_USER=tenpo
POSTGRES_PASSWORD=set_me_in_local_env
