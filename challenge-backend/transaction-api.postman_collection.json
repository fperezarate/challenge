{
  "info": {
    "name": "Transaction API - Tenpo",
    "_postman_id": "b5b7f3c0-0000-0000-0000-transaction-api-tenpo",
    "description": "Colección Postman para la Transaction API de Tenpo.\nIncluye ejemplos de uso con headers de idempotencia (X-Idempotency-Key) y trazabilidad (X-Request-ID).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET /transaction - Listar transacciones",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "X-Request-ID",
            "value": "11111111-1111-1111-1111-111111111111",
            "description": "UUID para correlación de logs. Puedes cambiarlo por un nuevo UUID en cada llamada."
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/transaction",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "transaction"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST /transaction - Crear transacción (idempotente)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "X-Idempotency-Key",
            "value": "22222222-2222-2222-2222-222222222222",
            "description": "UUID V4. Usa el mismo valor en reintentos para que el backend reconozca la misma operación."
          },
          {
            "key": "X-Request-ID",
            "value": "33333333-3333-3333-3333-333333333333",
            "description": "UUID para trazabilidad en logs."
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"monto\": 1000,\n  \"giroComercio\": \"Comercio Test\",\n  \"nombreTenpista\": \"Tenpista Test\",\n  \"fechaTransaccion\": \"2026-03-09T10:30:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/transaction",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "transaction"
          ]
        },
        "description": "Crea una transacción. Reutiliza el mismo X-Idempotency-Key para probar idempotencia (debería devolver siempre la misma transacción)."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}

