<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Formato de consola con colores: timestamp [requestId] thread LEVEL logger - msg -->
    <!-- %clr y %highlight son conversores de Spring Boot que aplican ANSI a la salida de consola -->
    <!-- Fecha (amarillo) + hora (verde) para facilitar lectura temporal -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{yyyy-MM-dd}){yellow} %clr(%d{HH:mm:ss.SSS}){green} [%clr(%X{requestId:-}){magenta}] [%clr(%thread){blue}] %highlight(%-5level) %clr(%logger{40}){cyan} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Nivel por defecto -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Aplicación: más detalle para debugear -->
    <logger name="com.challenge.transaction" level="DEBUG"/>
    <!-- Hibernate SQL (opcional; ya show-sql en properties, aquí se puede controlar nivel) -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>
    <!-- Reducir ruido de otros paquetes -->
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.boot" level="INFO"/>
</configuration>
